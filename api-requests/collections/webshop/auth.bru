meta {
  name: auth
  type: http
  seq: 1
}

post {
  url: {{auth_base_URL}}/auth/login
  body: formUrlEncoded
  auth: inherit
}

body:form-urlencoded {
  username: user
  password: pass
}

assert {
  res.status: eq 200
  res.body.token: isDefined
}

script:post-response {
  bru.setVar("authToken", res.body.token)
}

settings {
  encodeUrl: true
  timeout: 0
}
